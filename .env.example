# =============================================================================
# Template de variaveis de ambiente;
# Copie este arquivo para .env e preencha os valores reais;
# =============================================================================

# --- Banco de dados PostgreSQL (pipeline F1) ---
DB_HOST=localhost
DB_NAME=f1db
DB_USER=airflow
DB_PASSWORD=airflow
DB_PORT=5432

# --- Airflow (opcional; usado pelo docker-compose.yaml) ---
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.
AIRFLOW_IMAGE_NAME=apache/airflow:3.2.1

# --- Seguranca Airflow (altere em producao) ---
FERNET_KEY=
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret
