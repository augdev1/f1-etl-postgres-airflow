# =============================================================================
# Template de variaveis de ambiente para o Airflow (Docker Compose);
# Copie este arquivo para .env e preencha os valores reais;
# NAO versione o arquivo .env;
# =============================================================================

# --- Identidade do container ---
AIRFLOW_UID=
AIRFLOW_PROJ_DIR=.

# --- Imagem do Airflow ---
AIRFLOW_IMAGE_NAME=

# --- Seguranca ---
# Gere uma FERNET_KEY com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
AIRFLOW__API_AUTH__JWT_SECRET=

# --- Python path para encontrar pacotes customizados ---
PYTHONPATH=/opt/airflow
